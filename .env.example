# =============================================================================
# HRTech - Variáveis de Ambiente (TEMPLATE)
# =============================================================================
# INSTRUÇÕES:
# 1. Copie este arquivo para .env
# 2. Preencha TODOS os valores obrigatórios
# 3. NUNCA commite o arquivo .env no Git
#
# Para gerar uma SECRET_KEY segura:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

# -----------------------------------------------------------------------------
# Django (OBRIGATÓRIO)
# -----------------------------------------------------------------------------
SECRET_KEY=<GERE_UMA_CHAVE_SEGURA_COM_50+_CARACTERES>
DEBUG=False
ALLOWED_HOSTS=seu-dominio.com

# -----------------------------------------------------------------------------
# PostgreSQL (OBRIGATÓRIO)
# -----------------------------------------------------------------------------
DB_NAME=<nome_do_banco>
DB_USER=<usuario>
DB_PASSWORD=<senha_forte>
DB_HOST=localhost
DB_PORT=5432

# -----------------------------------------------------------------------------
# Neo4j AuraDB (OBRIGATÓRIO)
# -----------------------------------------------------------------------------
NEO4J_URI=<sua_uri_neo4j>
NEO4J_USER=<usuario>
NEO4J_PASSWORD=<senha>

# -----------------------------------------------------------------------------
# AWS S3 (opcional - necessário para upload de CVs)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
AWS_PRESIGNED_URL_TTL=900

# -----------------------------------------------------------------------------
# Celery + Redis (opcional - necessário para processamento assíncrono)
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# OpenAI (opcional - necessário para extração de skills de CVs)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
