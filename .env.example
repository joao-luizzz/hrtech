# HRTech Interview Assistant - Production Environment Configuration
# ================================================================
#
# CRITICAL: This file is an EXAMPLE. DO NOT COMMIT PRODUCTION SECRETS.
# Use Render Dashboard > Environment > Add Variable for each setting.
#
# All variables marked [REQUIRED] must be set before production deployment.
# All variables marked [OPTIONAL] can be left empty (defaults will be used).

# =============================================================================
# ENVIRONMENT - DEVELOPMENT / STAGING / PRODUCTION [RECOMMENDED]
# =============================================================================
# Set which environment this is running in
# development  = local machine, DEBUG=True, LocMemCache (memory)
# staging      = pre-production testing, DEBUG=False, Redis cache
# production   = live environment, DEBUG=False, Redis cache
# 
# Default: development (if not set)
ENVIRONMENT=development  # [RECOMMENDED] Set to: development, staging, or production

# =============================================================================
# DJANGO CONFIGURATION [REQUIRED FOR PRODUCTION]
# =============================================================================


# Django secret key - MUST be unique and strong per environment
# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-in-production  # [REQUIRED] Use get_random_secret_key()

# Debug mode - MUST be False in production
DEBUG=False  # [REQUIRED] Never True in production

# Allowed hosts for production domain
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com  # [REQUIRED] Production domain

# CSRF trusted origins for HTMX requests
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com  # [REQUIRED]

# X-Frame-Options header (prevent clickjacking)
X_FRAME_OPTIONS=DENY  # [REQUIRED] DENY recommended for security

# =============================================================================
# DATABASE [REQUIRED - PostgreSQL for Production]
# =============================================================================

# DATABASE_URL format: postgresql://user:password@host:port/database
# Example: postgresql://hrtech_user:strong_password@db.render.com:5432/hrtech_prod
DATABASE_URL=postgresql://user:password@db.render.com:5432/hrtech_prod  # [REQUIRED]

# Legacy format (will be deprecated, use DATABASE_URL instead)
DB_NAME=hrtech_prod  # [OPTIONAL]
DB_USER=hrtech_user  # [OPTIONAL]
DB_PASSWORD=strong_password_here  # [OPTIONAL]
DB_HOST=db.render.com  # [OPTIONAL]
DB_PORT=5432  # [OPTIONAL]

# =============================================================================
# NEO4J CONFIGURATION [REQUIRED]
# =============================================================================

# Neo4j AuraDB connection (get from Aura Dashboard > Connection Details)
# Format: neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_URI=neo4j+s://xxxxx.databases.neo4j.io  # [REQUIRED] From Aura Dashboard

# Neo4j authentication
NEO4J_USER=neo4j  # [REQUIRED] Default user for Aura
NEO4J_PASSWORD=change-me  # [REQUIRED] From Aura Dashboard

# =============================================================================
# REDIS / CELERY & CACHING STRATEGY [REQUIRED FOR PRODUCTION]
# =============================================================================
# 
# IMPORTANT: Cache strategy depends on ENVIRONMENT:
# 
# DEVELOPMENT (LocMemCache - in memory):
# - Leave these empty or commented out below
# - Django will use in-memory cache (LocMemCache)
# - No Redis needed for local development
# - Cache is NOT shared between multiple processes
# - Cache is lost when Django restarts
# - Template changes visible after Ctrl+Shift+R (no need to restart Django)
# - Use: python scripts/clean_cache.py when needed
#
# STAGING/PRODUCTION (Redis - distributed):
# - Configure CELERY_BROKER_URL and CACHE_URL with Redis endpoint
# - Redis is shared across all Django workers (multi-process safe)
# - Cache persists even after Django restart
# - Use: redis-cli FLUSHALL to clear cache when templates change
# - Recommended: Upstash (free tier), Redis Cloud, or Render add-on

# Redis URL for Celery broker and async task queue
# Format: redis://[user]:[password]@[host]:[port]/[db]
# Examples:
#   - Development: Leave empty to disable
#   - Production: redis://default:very-strong-password@upstash.io:12345/0
# CRITICAL: In production, change password from default!
CELERY_BROKER_URL=  # [OPTIONAL FOR DEV] [REQUIRED FOR PROD] Use Upstash Redis or equivalent

# Redis result backend (stores task results)
# Can be same as CELERY_BROKER_URL
CELERY_RESULT_BACKEND=  # [OPTIONAL FOR DEV] [REQUIRED FOR PROD] Usually same as CELERY_BROKER_URL

# Cache URL (shared rate limiting and session storage in production)
# In production, can reuse CELERY_BROKER_URL (different DB number) or separate Redis instance
# If empty and CELERY_BROKER_URL is set, will use CELERY_BROKER_URL for cache
# If both empty in development, uses in-memory LocMemCache (fast, no external dependency)
CACHE_URL=  # [OPTIONAL FOR DEV] [OPTIONAL FOR PROD] Leave empty in dev, use Redis endpoint in prod

# =============================================================================
# OPENAI API [REQUIRED FOR INTERVIEW FEATURE]
# =============================================================================

# OpenAI API Key (get from https://platform.openai.com/account/api-keys)
# Format: Must start with "sk-" and be 48+ characters
OPENAI_API_KEY=sk-...  # [REQUIRED] From OpenAI API Dashboard

# OpenAI model to use for interview questions
OPENAI_MODEL=gpt-4o-mini  # [REQUIRED] Currently using gpt-4o-mini

# OpenAI timeout (seconds) - max wait for API response
OPENAI_TIMEOUT_SECONDS=15  # [OPTIONAL] Default: 15 seconds

# OpenAI mock mode (for testing without real API calls)
OPENAI_MOCK_MODE=False  # [OPTIONAL] Default: False (use real API)

# =============================================================================
# AWS S3 (FOR CV STORAGE) [REQUIRED]
# =============================================================================

# AWS IAM Access Key (get from AWS IAM > Users > Create Access Key)
AWS_ACCESS_KEY_ID=AKIA...  # [REQUIRED] From AWS IAM

# AWS IAM Secret Key
AWS_SECRET_ACCESS_KEY=...  # [REQUIRED] From AWS IAM (keep secret!)

# S3 bucket name for CV storage
AWS_STORAGE_BUCKET_NAME=hrtech-cvs-prod  # [REQUIRED] Must exist in S3

# AWS S3 region
AWS_S3_REGION_NAME=us-east-1  # [OPTIONAL] Default: us-east-1

# Presigned URL TTL (seconds) - how long URLs are valid
AWS_PRESIGNED_URL_TTL=900  # [OPTIONAL] 900s = 15 minutes

# =============================================================================
# EMAIL CONFIGURATION [OPTIONAL - For notifications]
# =============================================================================

# SMTP email backend
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend  # [OPTIONAL]

# Gmail SMTP (or your mail provider)
EMAIL_HOST=smtp.gmail.com  # [OPTIONAL]
EMAIL_PORT=587  # [OPTIONAL]

# Email credentials
EMAIL_HOST_USER=your-email@gmail.com  # [OPTIONAL]
EMAIL_HOST_PASSWORD=your-app-password  # [OPTIONAL] Use app-specific password for Gmail

# Default sender email
DEFAULT_FROM_EMAIL=noreply@yourdomain.com  # [OPTIONAL]

# =============================================================================
# ERROR TRACKING (SENTRY) [OPTIONAL]
# =============================================================================

# Sentry DSN for error tracking (get from Sentry > Projects > Settings)
# Format: https://key@sentry.io/project_id
SENTRY_DSN=https://...@sentry.io/...  # [OPTIONAL] Leave empty to disable

# =============================================================================
# RENDER DEPLOYMENT [OPTIONAL - For CI/CD]
# =============================================================================

# Render deployment hook (for automated deployments)
RENDER_DEPLOY_HOOK=https://api.render.com/deploy/srv-...  # [OPTIONAL]

# =============================================================================
# INITIAL SETUP [OPTIONAL - For onboarding RH staff]
# =============================================================================

# RH admin bootstrap (used in migrations/management commands)
RH_ADMIN_EMAIL=rh@empresa.com  # [OPTIONAL]
RH_ADMIN_USERNAME=admin_rh  # [OPTIONAL]
RH_ADMIN_PASSWORD=strong_password  # [OPTIONAL]

# Site domain (for email links, etc.)
SITE_DOMAIN=yourdomain.com  # [OPTIONAL]

# =============================================================================
# SECURITY HEADERS [REQUIRED - Controlled via Django Settings]
# =============================================================================

# These are configured in core/settings.py:
# - SECURE_HSTS_SECONDS = 31536000 (1 year)
# - SECURE_SSL_REDIRECT = True (HTTPS only)
# - CSRF_COOKIE_SECURE = True (HTTPS only)
# - SESSION_COOKIE_SECURE = True (HTTPS only)
# - X-Frame-Options = DENY (prevent clickjacking)
# 
# NOTE: These are set automatically in production (when DEBUG=False).
# No need to configure here.

# =============================================================================
# VERIFICATION CHECKLIST
# =============================================================================

# Before deployment, verify all [REQUIRED] variables are set:
# 
# [ ] SECRET_KEY is unique and strong (not default)
# [ ] DEBUG = False
# [ ] ALLOWED_HOSTS includes production domain
# [ ] CSRF_TRUSTED_ORIGINS includes production domain
# [ ] DATABASE_URL is PostgreSQL (not SQLite)
# [ ] NEO4J_URI, USER, PASSWORD from Aura Dashboard
# [ ] CELERY_BROKER_URL is Redis (production instance)
# [ ] CELERY_RESULT_BACKEND is Redis
# [ ] OPENAI_API_KEY is set (starts with "sk-")
# [ ] AWS_ACCESS_KEY_ID, SECRET_ACCESS_KEY, BUCKET set
# [ ] No passwords or secrets hardcoded in code
# [ ] All secrets loaded from this environment file (not git)
#
# Use: python manage.py check --deploy

