# Django
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
X_FRAME_OPTIONS=SAMEORIGIN

# PostgreSQL
DB_NAME=hrtech
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Neo4j AuraDB
NEO4J_URI=neo4j+s://xxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me

# Redis / Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
# Cache compartilhado (rate limiting distribuido em producao)
# Em producao, usar Redis dedicado (pode reutilizar o mesmo endpoint do broker)
CACHE_URL=redis://localhost:6379/1

# OpenAI
OPENAI_API_KEY=
OPENAI_MOCK_MODE=True

# AWS S3 (opcional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=hrtech-cvs
AWS_S3_REGION_NAME=us-east-1
AWS_PRESIGNED_URL_TTL=900

# Email (producao)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@hrtech.com

# RH bootstrap (migrations/comando setup_rh)
RH_ADMIN_EMAIL=rh@empresa.com
RH_ADMIN_USERNAME=admin_rh
RH_ADMIN_PASSWORD=
